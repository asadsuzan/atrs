PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/atrs

# Transport / CORS
# Comma-separated list of allowed browser origins for cross-origin requests.
# Requests with no Origin header (curl, server-to-server) are always allowed.
# Defaults to the vite dev origins if unset.
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Root admin (seeded on first boot if no root admin exists)
ROOT_ADMIN_EMAIL=admin@example.com
ROOT_ADMIN_PASSWORD=change-me-strong-password
ROOT_ADMIN_NAME=Root Admin
